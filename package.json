{
  "name": "vox",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "vox": "dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup src/cli.ts --format esm --target node22 --sourcemap --clean",
    "start": "node dist/cli.js",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "test": "node --import tsx --test",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "pnpm run format:check && oxlint --deny-warnings src test",
    "lint:fix": "pnpm run format && oxlint --fix src test"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "7.0.0-dev.20260514.1",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.2"
}
